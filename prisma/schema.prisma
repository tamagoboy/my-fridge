generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// 認証テーブル（Google OAuth のみ対応）
// ─────────────────────────────────────────────

model User {
  id       String  @id @default(cuid())
  googleId String  @unique
  name     String?
  email    String  @unique
  image    String?

  fridgeMember FridgeMember?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// 冷蔵庫共有テーブル
// ─────────────────────────────────────────────

model Fridge {
  id   String @id @default(cuid())
  name String @default("マイ冷蔵庫")

  members          FridgeMember[]
  foods            Food[]
  invitations      FridgeInvitation[]
  storageLocations StorageLocation[]
  inputHistories   InputHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FridgeMember {
  id       String @id @default(cuid())
  userId   String @unique
  fridgeId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fridge Fridge @relation(fields: [fridgeId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@index([fridgeId])
}

model FridgeInvitation {
  id        String   @id @default(cuid())
  fridgeId  String
  token     String   @unique @default(uuid())
  expiresAt DateTime

  fridge Fridge @relation(fields: [fridgeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// アプリケーションテーブル
// ─────────────────────────────────────────────

// 保管場所（初回ログイン時にデフォルト3つ自動作成）
model StorageLocation {
  id        String @id @default(cuid())
  name      String
  sortOrder Int    @default(0)
  fridgeId  String

  fridge Fridge @relation(fields: [fridgeId], references: [id], onDelete: Cascade)
  foods  Food[]

  @@unique([fridgeId, name])
  @@index([fridgeId])
}

// 食材テーブル
model Food {
  id                String    @id @default(cuid())
  name              String
  category          String?
  remainingStatus   String    @default("full") // 'full'|'half'|'little'
  storageLocationId String?
  fridgeId          String
  expiryDate        DateTime? // Phase 2 (Step 11) で使用

  fridge          Fridge           @relation(fields: [fridgeId], references: [id], onDelete: Cascade)
  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fridgeId])
  @@index([fridgeId, storageLocationId])
  @@index([fridgeId, expiryDate])
}

// 入力履歴（Step 10 サジェスト用）
model InputHistory {
  id       String @id @default(cuid())
  fridgeId String
  name     String
  category String?
  count    Int    @default(1)

  fridge Fridge @relation(fields: [fridgeId], references: [id], onDelete: Cascade)

  @@unique([fridgeId, name])
  @@index([fridgeId])
}
